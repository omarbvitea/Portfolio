---
const {title, provider, credential, icon} = Astro.props
---
<a href={credential} target="_blank" rel="noopener noreferrer" class="group flex w-full items-center justify-between transition-all duration-300 hover:scale-110 hover:shadow-stone-200 hover:shadow-xl rounded-2xl p-3">
  <div class="flex items-center gap-4">
    <img src={icon} alt="Logo certificado" class="h-12 w-12 rounded-full object-cover shadow-md transition-all duration-300"/>
    <div class="flex flex-col">
        <h3 class="font-medium transition-colors duration-300">{title}</h3>
        <span class="font-light text-sm sm:text-base transition-colors duration-300">{provider}</span>
      </div>
  </div>
</a>
